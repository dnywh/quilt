---
import type { CollectionEntry } from "astro:content";
import TroveItem from "./TroveItem.astro";

interface Props {
  entries: CollectionEntry<"trove">[];
}

const { entries } = Astro.props;
---

<ul class="trove-list">
  {entries.map((entry) => <TroveItem entry={entry} />)}
</ul>

<style>
  .trove-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }
</style>
