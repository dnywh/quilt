---
import { getCollection } from "astro:content";
import TroveList from "./TroveList.astro";

const trove = await getCollection("trove");
const sortedTrove = trove.sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);
---

<section id="trove">
  <h2>Trove</h2>
  <p class="trove-intro">
    Links worth keeping. <a href="/trove/">View all</a>
  </p>
  <TroveList entries={sortedTrove} />
</section>

<style>
  .trove-intro {
    margin: 0 0 1.5rem;
    color: #6b7280;
    font-size: 0.9375rem;
  }

  .trove-intro a {
    color: #111827;
  }
</style>
