---
import ListItem from "./ListItem.astro";
import { getListPageUrl, LIST_FILTERS, type DatedListItem } from "../../lib/list";

interface Props {
  items: DatedListItem[];
  currentPage: number;
  totalPages: number;
}

const { items, currentPage, totalPages } = Astro.props;
---

<main class="list-page">
  <header class="list-header">
    <h1>List</h1>
    <fieldset class="list-filters">
      <legend class="list-filters-legend">Filter by type</legend>
      {
        LIST_FILTERS.map(({ kind, label, id }) => (
          <>
            <input type="checkbox" id={id} checked class="list-filter-input" />
            <label for={id} class="list-filter-label" data-kind={kind}>
              {label}
            </label>
          </>
        ))
      }
    </fieldset>
  </header>

  <section class="list-items">
    {items.map((item) => <ListItem item={item} />)}
  </section>

  {
    totalPages > 1 && (
      <nav class="list-pagination" aria-label="Pagination">
        {
          currentPage > 1 ? (
            <a class="list-pagination-link" href={getListPageUrl(currentPage - 1)}>
              Previous
            </a>
          ) : (
            <span class="list-pagination-spacer" aria-hidden="true" />
          )
        }
        <span class="list-pagination-status">
          Page {currentPage} of {totalPages}
        </span>
        {
          currentPage < totalPages ? (
            <a class="list-pagination-link" href={getListPageUrl(currentPage + 1)}>
              Next
            </a>
          ) : (
            <span class="list-pagination-spacer" aria-hidden="true" />
          )
        }
      </nav>
    )
  }
</main>

<style>
  .list-page {
    max-width: 760px;
    margin: 0 auto;
    padding: 2rem 1rem 4rem;
  }

  .list-header {
    margin-bottom: 2.5rem;
  }

  .list-header h1 {
    margin: 0 0 1.25rem;
  }

  .list-filters {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin: 0;
    padding: 0;
    border: none;
  }

  .list-filters-legend {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .list-filter-input {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .list-filter-label {
    display: inline-block;
    padding: 0.375rem 0.75rem;
    font-size: 0.875rem;
    color: #6b7280;
    background: #f3f4f6;
    border: 1px solid #e5e7eb;
    border-radius: 999px;
    cursor: pointer;
    user-select: none;
  }

  .list-filter-input:checked + .list-filter-label {
    color: #111827;
    background: #e5e7eb;
    border-color: #d1d5db;
  }

  .list-filter-input:focus-visible + .list-filter-label {
    outline: 2px solid #111827;
    outline-offset: 2px;
  }

  .list-items {
    display: grid;
    gap: 3rem;
  }

  .list-pagination {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 1rem;
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid #e5e7eb;
  }

  .list-pagination-link {
    color: #111827;
    font-size: 0.9375rem;
    text-decoration: none;
  }

  .list-pagination-link:hover {
    color: #4b5563;
  }

  .list-pagination-link:first-child {
    justify-self: start;
  }

  .list-pagination-link:last-child {
    justify-self: end;
  }

  .list-pagination-status {
    color: #6b7280;
    font-size: 0.875rem;
    text-align: center;
  }

  .list-pagination-spacer {
    display: block;
  }

  .list-page:has(#filter-note:not(:checked)) :global(.list-item[data-kind="note"]) {
    display: none;
  }

  .list-page:has(#filter-trove:not(:checked)) :global(.list-item[data-kind="trove"]) {
    display: none;
  }

  .list-page:has(#filter-ephemera:not(:checked))
    :global(.list-item[data-kind="ephemera"]) {
    display: none;
  }

  .list-page:has(#filter-photo:not(:checked)) :global(.list-item[data-kind="photo"]) {
    display: none;
  }

  .list-page:has(#filter-soundscape:not(:checked))
    :global(.list-item[data-kind="soundscape"]) {
    display: none;
  }
</style>
